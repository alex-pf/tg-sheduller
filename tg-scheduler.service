[Unit]
Description=Telegram Scheduler Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/tg-scheduler
EnvironmentFile=/opt/tg-scheduler/.env
ExecStart=/opt/tg-scheduler/venv/bin/python main.py
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tg-scheduler

[Install]
WantedBy=multi-user.target
